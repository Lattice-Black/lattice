// Lattice API Database Schema
// Unified schema for service discovery + authentication
// Version: 2.0.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Authentication Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  apiKeys       ApiKey[]
  subscription  Subscription?
  services      Service[]

  @@map("users")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  keyHash   String    @unique @map("key_hash")
  name      String?   @default("Default API Key")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  inactive
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique @map("user_id")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  status               SubscriptionStatus @default(inactive)
  plan                 String?            @default("free")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  trialEnd             DateTime?          @map("trial_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// Service Discovery Models
// ============================================

enum ServiceStatus {
  active
  inactive
  unknown
}

model Service {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  name             String
  version          String?
  environment      String?
  deploymentType   String?       @map("deployment_type")
  language         String
  framework        String
  runtime          String?
  description      String?
  repository       String?
  healthCheckUrl   String?       @map("health_check_url")
  status           ServiceStatus @default(unknown)
  firstSeen        DateTime      @default(now()) @map("first_seen")
  lastSeen         DateTime      @default(now()) @map("last_seen")
  discoveredBy     Json?         @map("discovered_by")
  metadata         Json?
  totalRequests    Int           @default(0) @map("total_requests")
  avgResponseTimeMs Int          @default(0) @map("avg_response_time_ms")
  errorRate        Decimal       @default(0) @db.Decimal(5, 2) @map("error_rate")
  lastMetricUpdate DateTime?     @map("last_metric_update")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics ServiceMetric[]
  routes  Route[]
  dependencies Dependency[]
  outgoingConnections Connection[] @relation("SourceService")
  incomingConnections Connection[] @relation("TargetService")

  @@unique([userId, name])
  @@index([userId])
  @@index([name])
  @@index([status])
  @@index([lastSeen])
  @@map("services")
}

model ServiceMetric {
  id                String   @id @default(cuid())
  serviceId         String   @map("service_id")
  method            String
  path              String
  statusCode        Int      @map("status_code")
  responseTimeMs    Int      @map("response_time_ms")
  callerServiceName String?  @map("caller_service_name")
  timestamp         DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([timestamp])
  @@map("service_metrics")
}

// Route entity - HTTP endpoints within services
model Route {
  id                String   @id @default(cuid())
  serviceId         String   @map("service_id")
  method            String
  path              String
  middlewareChain   String[] @map("middleware_chain")
  handlerLocation   Json?    @map("handler_location")
  pathParameters    Json?    @map("path_parameters")
  queryParameters   Json?    @map("query_parameters")
  requestSchema     Json?    @map("request_schema")
  responseSchema    Json?    @map("response_schema")
  description       String?
  tags              String[]
  avgResponseTimeMs Float?   @map("avg_response_time_ms")
  callFrequency     Float?   @map("call_frequency")
  errorRate         Float?   @map("error_rate")
  firstSeen         DateTime @default(now()) @map("first_seen")
  lastSeen          DateTime @updatedAt @map("last_seen")
  metadata          Json?

  service           Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  connections       Connection[] @relation("TargetRoute")

  @@unique([serviceId, method, path])
  @@index([serviceId])
  @@index([method])
  @@map("routes")
}

// Dependency entity - External packages used by services
model Dependency {
  id                  String   @id @default(cuid())
  serviceId           String   @map("service_id")
  packageName         String   @map("package_name")
  version             String
  versionRange        String?  @map("version_range")
  dependencyType      String   @map("dependency_type")
  scope               String?
  installedSize       Int?     @map("installed_size")
  publishSize         Int?     @map("publish_size")
  fileCount           Int?     @map("file_count")
  hasVulnerabilities  Boolean? @map("has_vulnerabilities")
  vulnerabilityCount  Int?     @map("vulnerability_count")
  highestSeverity     String?  @map("highest_severity")
  description         String?
  license             String?
  repository          String?
  homepage            String?
  firstSeen           DateTime @default(now()) @map("first_seen")
  lastSeen            DateTime @updatedAt @map("last_seen")
  metadata            Json?

  service             Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, packageName])
  @@index([serviceId])
  @@index([packageName])
  @@index([hasVulnerabilities])
  @@map("dependencies")
}

// Connection entity - Service-to-service communication edges
model Connection {
  id                  String   @id @default(cuid())
  sourceServiceId     String   @map("source_service_id")
  targetServiceId     String   @map("target_service_id")
  targetRouteId       String?  @map("target_route_id")
  method              String
  path                String
  callCount           Int      @default(0) @map("call_count")
  avgResponseTimeMs   Float?   @map("avg_response_time_ms")
  p95ResponseTimeMs   Float?   @map("p95_response_time_ms")
  p99ResponseTimeMs   Float?   @map("p99_response_time_ms")
  successCount        Int      @default(0) @map("success_count")
  errorCount          Int      @default(0) @map("error_count")
  errorRate           Float    @default(0) @map("error_rate")
  requestFrequency    Float?   @map("request_frequency")
  peakTime            String?  @map("peak_time")
  firstSeen           DateTime @default(now()) @map("first_seen")
  lastSeen            DateTime @updatedAt @map("last_seen")
  sampleTraceIds      String[] @map("sample_trace_ids")
  metadata            Json?

  sourceService       Service  @relation("SourceService", fields: [sourceServiceId], references: [id], onDelete: Cascade)
  targetService       Service  @relation("TargetService", fields: [targetServiceId], references: [id], onDelete: Cascade)
  targetRoute         Route?   @relation("TargetRoute", fields: [targetRouteId], references: [id], onDelete: SetNull)

  @@unique([sourceServiceId, targetServiceId, method, path])
  @@index([sourceServiceId])
  @@index([targetServiceId])
  @@index([sourceServiceId, targetServiceId])
  @@index([lastSeen])
  @@map("connections")
}

// Plugin registry - Framework-specific analyzers
model Plugin {
  id                      String   @id @default(cuid())
  name                    String   @unique
  version                 String
  supportedFrameworks     String[] @map("supported_frameworks")
  supportedSchemaVersions String[] @map("supported_schema_versions")
  preferredSchemaVersion  String   @map("preferred_schema_version")
  canDiscoverRoutes       Boolean  @default(false) @map("can_discover_routes")
  canDiscoverDependencies Boolean  @default(false) @map("can_discover_dependencies")
  canTrackConnections     Boolean  @default(false) @map("can_track_connections")
  description             String?
  author                  String?
  repository              String?
  documentation           String?
  servicesUsing           Int      @default(0) @map("services_using")
  registeredAt            DateTime @default(now()) @map("registered_at")
  lastUsed                DateTime? @map("last_used")
  metadata                Json?

  @@index([name])
  @@map("plugins")
}
