// Prisma schema for Lattice with Auth.js
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Auth.js Required Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials provider
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  subscription  Subscription?
  services      Service[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// Lattice Application Models
// ============================================

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  keyHash   String    @unique
  name      String?   @default("Default API Key")
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  inactive
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               SubscriptionStatus @default(inactive)
  plan                 String?            @default("free")
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum ServiceStatus {
  active
  inactive
  unknown
}

model Service {
  id               String        @id @default(cuid())
  userId           String
  name             String
  version          String?
  environment      String?
  deploymentType   String?
  language         String
  framework        String
  runtime          String?
  description      String?
  repository       String?
  healthCheckUrl   String?
  status           ServiceStatus @default(unknown)
  firstSeen        DateTime      @default(now())
  lastSeen         DateTime      @default(now())
  discoveredBy     Json?
  metadata         Json?
  totalRequests    Int           @default(0)
  avgResponseTimeMs Int          @default(0)
  errorRate        Decimal       @default(0) @db.Decimal(5, 2)
  lastMetricUpdate DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics ServiceMetric[]

  @@unique([userId, name])
  @@index([userId])
  @@map("services")
}

model ServiceMetric {
  id                String   @id @default(cuid())
  serviceId         String
  method            String
  path              String
  statusCode        Int
  responseTimeMs    Int
  callerServiceName String?
  timestamp         DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([timestamp])
  @@map("service_metrics")
}
